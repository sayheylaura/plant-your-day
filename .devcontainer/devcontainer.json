{
  "name": "plant-your-day-dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/code",
  "shutdownAction": "stopCompose",
  "initializeCommand": "test -f .env || cp .env.example .env",
  "postCreateCommand": "cd backend && (test -d .venv || uv venv) && uv pip install --python .venv/bin/python -r requirements.txt && cd ../frontend && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-python.debugpy",
        "ms-python.isort",
        "ms-python.python",
        "ms-python.vscode-python-envs",
        "vue.volar"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/code/backend/.venv/bin/python"
      }
    }
  }
}
