{
  "name": "plant-your-day-dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/code",
  "postCreateCommand": "cd backend && uv venv && uv pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-python.debugpy",
        "ms-python.isort",
        "ms-python.python",
        "ms-python.vscode-python-envs",
        "vue.volar"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/code/backend/.venv/bin/python"
      }
    }
  }
}
